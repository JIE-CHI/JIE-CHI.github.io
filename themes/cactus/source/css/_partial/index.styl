.post-list
  padding: 0

  .post-item
    margin-bottom: 1rem
    margin-left: 0
    list-style-type: none

    .meta
      display: block
      margin-right: 16px
      min-width: 100px
      color: $color-meta
      font-size: 14px

@media (min-width: 480px)
  .post-list
    .post-item
      display: flex
      margin-bottom: 5px

      .meta
        text-align: left

.project-list
  padding: 0
  list-style: none

  .project-item
    margin-bottom: 5px
    p
      display: inline

.academic-intro
  margin-bottom: 2rem

.interest-list
  padding-left: 1.2rem

  li
    margin-bottom: .35rem

.publication-list
  padding: 0
  list-style: none

  .publication-item
    margin-bottom: 1rem

  .publication-title
    display: block
    font-weight: 600

  .publication-authors,
  .publication-venue
    display: block
    color: $color-meta
    font-size: .95rem
