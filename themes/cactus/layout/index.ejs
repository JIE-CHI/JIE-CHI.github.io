<section id="about" class="p-note academic-intro">
  <% if (config.description) { %>
    <%- markdown(config.description) %>
  <% } %>
  <% if (theme.social_links) { %>
    <p>
      <%= __('index.find_me_on') %>
      <% var nb_links = theme.social_links.length %>
      <% var i = 0 %>
      <% for(var {label, icon, link} of theme.social_links) { %>
        <% var title = label || icon %>
        <% if (icon == 'mail') { %>
          <a class="icon u-email" target="_blank" rel="noopener" href="<%- link %>" aria-label="<%- title %>" title="<%- title %>">
            <i class="fa-solid fa-envelope"></i><!--
      ---></a>
        <% } else if (icon == 'rss') { %>
          <a class="icon" target="_blank" rel="noopener" href="<%- link %>" aria-label="<%- title %>" title="<%- title %>">
            <i class="fa-solid fa-rss"></i>
          </a>
        <% } else { %>
          <a class="icon u-url" target="_blank" rel="noopener me" href="<%- url_for(link) %>" aria-label="<%- title %>" title="<%- title %>">
            <i class="fa-brands fa-<%= icon %>"></i><!--
      ---></a><!--
    ---><% } %><!--
    ---><%= ( nb_links > 0 && i < nb_links-1 ?
            ( i == nb_links-2 ? ' '+__('index.enum_and')+' '
            : __('index.enum_comma')+' ' )
            : '.' ) %>
        <% i+=1 %>
      <% } %>
    </p>
  <% } %>
</section>

<section id="research">
  <span class="h1">Research Interests</span>
  <ul class="interest-list">
    <li>Multilingual and code-switched automatic speech recognition</li>
    <li>Speech and language understanding beyond text-only representations</li>
    <li>Prosody, linguistic structure, and evaluation for speech and NLP systems</li>
  </ul>
</section>

<% if (site.data.publications) { %>
  <section id="selected-publications">
    <span class="h1"><a href="<%- url_for('/publications/') %>">Selected Publications</a></span>
    <ul class="publication-list">
      <% site.data.publications.forEach(function(pub) { %>
        <li class="publication-item">
          <span class="publication-title"><a href="<%- pub.url %>"><%= pub.title %></a></span>
          <span class="publication-authors"><%= pub.authors %></span>
          <span class="publication-venue"><%= pub.venue %></span>
        </li>
      <% }); %>
    </ul>
  </section>
<% } %>

<% if (site.data.projects) { %>
  <section id="news">
    <span class="h1">News</span>
    <ul class="project-list">
      <% var count = 0; %>
      <% for(var obj in site.data.projects) { %>
        <li class="project-item" style="<%= count >= 3 ? 'display: none;' : '' %>">
          <a href="<%= site.data.projects[obj].url %>"><%= site.data.projects[obj].name %></a>: 
          <%- markdown(site.data.projects[obj].desc) %>
        </li>
        <% count++; %>
      <% } %>
    </ul>
  
    <% if (count > 3) { %>
      <div class="show-more-container">
      <button id="show-more-btn" onclick="showMoreProjects()">See More News</button>
      </div>
    <% } %>
  </section>
  <% } %>

  <style>
    .show-more-container {
      width: 100%; /* Full width to center content */
      text-align: center; /* Centers inline elements inside */
      margin-top: 15px;
    }
  
    #show-more-btn {
      padding: 12px 18px;
      font-size: 14px;
      font-weight: bold;
      border-radius: 6px;
      cursor: pointer;
      border: 1px solid currentColor;
      background: transparent;
      display: inline-block; /* Ensures button respects text alignment */
    }
  
    #show-more-btn:hover {
      background: rgba(86, 124, 119, .1);
    }
  </style>
  <script>
    function showMoreProjects() {
      var items = document.querySelectorAll('.project-item');
      for (var i = 3; i < items.length; i++) {
        items[i].style.display = "list-item";
      }
      document.getElementById('show-more-btn').style.display = "none";
    }
  </script>
